# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_NAME=mehmat
DB_USER=mehmat
DB_PASSWORD=mehmat
DB_HOST=127.0.0.1
DB_PORT=5432

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Dedicated signing key for JWT. Falls back to SECRET_KEY when empty.
JWT_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------------
# Telegram Mini App
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456:your-bot-token
# Max age (seconds) of Telegram initData before it is rejected (24h default).
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# ---------------------------------------------------------------------------
# Media / static
# ---------------------------------------------------------------------------
MEDIA_ROOT=media
MEDIA_URL=/media/
STATIC_ROOT=staticfiles
STATIC_URL=/static/

# ---------------------------------------------------------------------------
# CORS (comma separated origins, e.g. your Mini App https origin)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://web.telegram.org
